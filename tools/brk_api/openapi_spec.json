{
  "openapi": "3.1.0",
  "info": {
    "title": "Bitcoin Research Kit (BRK)",
    "description": "Vendored upstream-aligned BRK reference spec for querying Bitcoin blockchain data, on-chain series, mining statistics, and market analytics. Used by Agent 21 to provide real-time Bitcoin data.",
    "version": "v0.2.3"
  },
  "servers": [
    {
      "url": "https://bitview.space"
    }
  ],
  "paths": {
    "/api/address/{address}": {
      "get": {
        "operationId": "getAddressInfo",
        "summary": "Get address information",
        "description": "Retrieve address information including balance and transaction counts. Supports P2PKH, P2SH, P2WPKH, P2WSH, P2TR.",
        "parameters": [
          {
            "in": "path",
            "name": "address",
            "required": true,
            "schema": { "type": "string" },
            "description": "Bitcoin address"
          }
        ],
        "responses": {
          "200": {
            "description": "Address stats",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AddressStats" }
              }
            }
          }
        }
      }
    },
    "/api/address/{address}/txs": {
      "get": {
        "operationId": "getAddressTxs",
        "summary": "Get address transactions",
        "description": "Get transaction IDs for an address, newest first. Use after_txid for pagination.",
        "parameters": [
          {
            "in": "path",
            "name": "address",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "in": "query",
            "name": "after_txid",
            "schema": { "type": "string" },
            "description": "Pagination cursor: txid to start after"
          },
          {
            "in": "query",
            "name": "limit",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of transaction IDs",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      }
    },
    "/api/address/{address}/utxo": {
      "get": {
        "operationId": "getAddressUtxos",
        "summary": "Get address UTXOs",
        "description": "Get unspent transaction outputs (UTXOs) for an address.",
        "parameters": [
          {
            "in": "path",
            "name": "address",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of UTXOs",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Utxo" } }
              }
            }
          }
        }
      }
    },
    "/api/v1/validate-address/{address}": {
      "get": {
        "operationId": "validateAddress",
        "summary": "Validate a Bitcoin address",
        "description": "Validate a Bitcoin address and get information about its type and scriptPubKey.",
        "parameters": [
          {
            "in": "path",
            "name": "address",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Validation result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AddressValidation" }
              }
            }
          }
        }
      }
    },
    "/api/blocks": {
      "get": {
        "operationId": "getRecentBlocks",
        "summary": "Get last 10 blocks",
        "description": "Retrieve the last 10 blocks with metadata.",
        "responses": {
          "200": {
            "description": "Array of block info",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/BlockInfo" } }
              }
            }
          }
        }
      }
    },
    "/api/block/{hash}": {
      "get": {
        "operationId": "getBlockByHash",
        "summary": "Get block by hash",
        "description": "Retrieve block information by block hash including height, timestamp, difficulty, size, weight, and tx count.",
        "parameters": [
          {
            "in": "path",
            "name": "hash",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Block info",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BlockInfo" }
              }
            }
          }
        }
      }
    },
    "/api/block-height/{height}": {
      "get": {
        "operationId": "getBlockByHeight",
        "summary": "Get block by height",
        "description": "Retrieve block information by block height.",
        "parameters": [
          {
            "in": "path",
            "name": "height",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Block info",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BlockInfo" }
              }
            }
          }
        }
      }
    },
    "/api/block/{hash}/txids": {
      "get": {
        "operationId": "getBlockTxids",
        "summary": "Get transaction IDs in a block",
        "description": "Retrieve all transaction IDs in a block.",
        "parameters": [
          {
            "in": "path",
            "name": "hash",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of txids",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      }
    },
    "/api/v1/mining/blocks/timestamp/{timestamp}": {
      "get": {
        "operationId": "getBlockByTimestamp",
        "summary": "Find block by timestamp",
        "description": "Find the block closest to a given UNIX timestamp.",
        "parameters": [
          {
            "in": "path",
            "name": "timestamp",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Block timestamp info",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BlockTimestamp" }
              }
            }
          }
        }
      }
    },
    "/api/mempool/info": {
      "get": {
        "operationId": "getMempoolInfo",
        "summary": "Get mempool statistics",
        "description": "Get current mempool statistics including transaction count, total vsize, and total fees.",
        "responses": {
          "200": {
            "description": "Mempool info",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MempoolInfo" }
              }
            }
          }
        }
      }
    },
    "/api/v1/fees/recommended": {
      "get": {
        "operationId": "getRecommendedFees",
        "summary": "Get recommended fee rates",
        "description": "Get recommended fee rates for different confirmation targets based on current mempool state.",
        "responses": {
          "200": {
            "description": "Recommended fees",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RecommendedFees" }
