    "/api/v1/mining/pools/{time_period}": {
      "get": {
        "operationId": "getMiningPools",
        "summary": "Get mining pool stats for a period",
        "description": "Get mining pool statistics for a time period. Valid periods: 24h, 3d, 1w, 1m, 3m, 6m, 1y, 2y, 3y",
        "parameters": [
          {
            "in": "path",
            "name": "time_period",
            "required": true,
            "schema": { "type": "string", "enum": ["24h", "3d", "1w", "1m", "3m", "6m", "1y", "2y", "3y"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Pool summary",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PoolsSummary" }
              }
            }
          }
        }
      }
    },
    "/api/v1/mining/pool/{slug}": {
      "get": {
        "operationId": "getMiningPoolDetail",
        "summary": "Get mining pool detail",
        "description": "Get detailed information about a specific mining pool.",
        "parameters": [
          {
            "in": "path",
            "name": "slug",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Pool detail",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PoolDetail" }
              }
            }
          }
        }
      }
    },
    "/api/v1/mining/hashrate/{time_period}": {
      "get": {
        "operationId": "getHashrate",
        "summary": "Get network hashrate and difficulty",
        "description": "Get network hashrate and difficulty data for a time period. Valid periods: 24h, 3d, 1w, 1m, 3m, 6m, 1y, 2y, 3y",
        "parameters": [
          {
            "in": "path",
            "name": "time_period",
            "required": true,
            "schema": { "type": "string", "enum": ["24h", "3d", "1w", "1m", "3m", "6m", "1y", "2y", "3y"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Hashrate summary",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HashrateSummary" }
              }
            }
          }
        }
      }
    },
    "/api/v1/mining/difficulty-adjustments/{time_period}": {
      "get": {
        "operationId": "getDifficultyAdjustments",
        "summary": "Get historical difficulty adjustments",
        "description": "Get historical difficulty adjustments for a time period. Valid periods: 24h, 3d, 1w, 1m, 3m, 6m, 1y, 2y, 3y",
        "parameters": [
          {
            "in": "path",
            "name": "time_period",
            "required": true,
            "schema": { "type": "string", "enum": ["24h", "3d", "1w", "1m", "3m", "6m", "1y", "2y", "3y"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of difficulty adjustments",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/DifficultyAdjustmentEntry" } }
              }
            }
          }
        }
      }
    },
    "/api/v1/mining/blocks/fees/{time_period}": {
      "get": {
        "operationId": "getBlockFees",
        "summary": "Get average block fees",
        "description": "Get average block fees for a time period. Valid periods: 24h, 3d, 1w, 1m, 3m, 6m, 1y, 2y, 3y",
        "parameters": [
          {
            "in": "path",
            "name": "time_period",
            "required": true,
            "schema": { "type": "string", "enum": ["24h", "3d", "1w", "1m", "3m", "6m", "1y", "2y", "3y"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Block fees data",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/BlockFeesEntry" } }
              }
            }
          }
        }
      }
    },
    "/api/v1/mining/blocks/rewards/{time_period}": {
      "get": {
        "operationId": "getBlockRewards",
        "summary": "Get average block rewards",
        "description": "Get average block rewards (subsidy + fees) for a time period. Valid periods: 24h, 3d, 1w, 1m, 3m, 6m, 1y, 2y, 3y",
        "parameters": [
          {
            "in": "path",
            "name": "time_period",
            "required": true,
            "schema": { "type": "string", "enum": ["24h", "3d", "1w", "1m", "3m", "6m", "1y", "2y", "3y"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Block rewards data",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/BlockRewardsEntry" } }
              }
            }
          }
        }
      }
    },
    "/api/v1/mining/blocks/sizes-weights/{time_period}": {
      "get": {
        "operationId": "getBlockSizesWeights",
        "summary": "Get average block sizes and weights",
        "description": "Get average block sizes and weights for a time period. Valid periods: 24h, 3d, 1w, 1m, 3m, 6m, 1y, 2y, 3y",
        "parameters": [
          {
            "in": "path",
            "name": "time_period",
            "required": true,
            "schema": { "type": "string", "enum": ["24h", "3d", "1w", "1m", "3m", "6m", "1y", "2y", "3y"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Block sizes and weights",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BlockSizesWeights" }
              }
            }
          }
        }
      }
    },
    "/api/v1/mining/reward-stats/{block_count}": {
      "get": {
        "operationId": "getRewardStats",
        "summary": "Get mining reward stats for last N blocks",
        "description": "Get mining reward statistics for the last N blocks.",
        "parameters": [
          {
            "in": "path",
            "name": "block_count",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Reward stats",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RewardStats" }
              }
            }
          }
        }
      }
    },
    "/api/tx/{txid}": {
      "get": {
        "operationId": "getTransaction",
        "summary": "Get transaction by txid",
        "description": "Retrieve complete transaction data including inputs, outputs, fee, size, and confirmation status.",
        "parameters": [
          {
            "in": "path",
            "name": "txid",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Transaction data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Transaction" }
              }
            }
          }
        }
      }
    },
    "/api/tx/{txid}/status": {
      "get": {
        "operationId": "getTransactionStatus",
        "summary": "Get transaction confirmation status",
        "description": "Returns whether the transaction is confirmed and block details if so.",
        "parameters": [
          {
            "in": "path",
            "name": "txid",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Transaction status",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TxStatus" }
              }
            }
          }
        }
      }
    },
    "/api/series/search": {
      "get": {
        "operationId": "searchSeries",
        "summary": "Fuzzy search for series",
        "description": "Fuzzy search for series by name. Supports partial matches and typos.",
        "parameters": [
          {
            "in": "query",
            "name": "q",
            "required": true,
            "schema": { "type": "string" },
            "description": "Search term for series name"
          },
          {
            "in": "query",
            "name": "limit",
            "schema": { "type": "integer" },
            "description": "Max results to return"
          }
        ],
        "responses": {
          "200": {
            "description": "Matching series names",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      }
    },
    "/api/series/indexes": {
      "get": {
        "operationId": "getSeriesIndexes",
        "summary": "List available indexes",
        "description": "Returns all available indexes with their accepted aliases.",
        "responses": {
          "200": {
            "description": "Available indexes",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/IndexInfo" } }
              }
            }
          }
        }
      }
    },
    "/api/series/{series}": {
      "get": {
        "operationId": "getSeriesInfo",
        "summary": "Get metadata for a series",
        "description": "Returns supported indexes and value type for the specified series.",
        "parameters": [
          {
            "in": "path",
            "name": "series",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Series metadata",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SeriesInfo" }
              }
            }
          }
        }
      }
    },
    "/api/series/{series}/{index}": {
      "get": {
        "operationId": "getSeriesData",
        "summary": "Fetch series data",
        "description": "Fetch data for a specific series at the given index. Supports CSV and JSON output.",
        "parameters": [
          {
            "in": "path",
            "name": "series",
            "required": true,
            "schema": { "type": "string" },
            "description": "Series name (for example price_close, market_cap, sopr_24h)"
          },
          {
            "in": "path",
            "name": "index",
            "required": true,
            "schema": { "type": "string" },
            "description": "Index alias or canonical index (for example day, week1, month1, year1, height)"
          },
          {
            "in": "query",
            "name": "start",
            "schema": {
              "oneOf": [
                { "type": "integer" },
                { "type": "string" }
              ]
            },
            "description": "Start bound. Supports negative offsets, absolute indexes, dates, and ISO timestamps."
          },
          {
            "in": "query",
            "name": "end",
            "schema": {
              "oneOf": [
                { "type": "integer" },
                { "type": "string" }
              ]
            },
            "description": "End bound. Supports negative offsets, absolute indexes, dates, and ISO timestamps."
          },
          {
            "in": "query",
            "name": "limit",
            "schema": { "type": "integer" },
            "description": "Max results to return"
          },
          {
            "in": "query",
            "name": "format",
            "schema": { "type": "string", "enum": ["json", "csv"] },
            "description": "Output format. Agent 21 defaults to csv for analytical retrieval."
          }
        ],
        "responses": {
          "200": {
            "description": "Series data",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SeriesData" }
              },
              "text/csv": {
                "schema": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "/api/series/{series}/{index}/data": {
      "get": {
        "operationId": "getSeriesDataRaw",
        "summary": "Fetch raw series values",
        "description": "Returns just the raw series values without the SeriesData wrapper.",
        "parameters": [
          {
            "in": "path",
            "name": "series",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "in": "path",
            "name": "index",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "in": "query",
            "name": "start",
            "schema": {
              "oneOf": [
                { "type": "integer" },
                { "type": "string" }
              ]
            }
          },
          {
            "in": "query",
            "name": "end",
            "schema": {
              "oneOf": [
                { "type": "integer" },
                { "type": "string" }
              ]
            }
          },
          {
            "in": "query",
            "name": "limit",
            "schema": { "type": "integer" }
          },
          {
            "in": "query",
            "name": "format",
            "schema": { "type": "string", "enum": ["json", "csv"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Raw series values",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": {} }
              },
              "text/csv": {
                "schema": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "/api/series/{series}/{index}/latest": {
      "get": {
        "operationId": "getSeriesLatest",
        "summary": "Fetch the latest value for a series",
        "description": "Returns the single most recent value for a series.",
        "parameters": [
          {
            "in": "path",
            "name": "series",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "in": "path",
            "name": "index",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Latest value",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/series/bulk": {
      "get": {
        "operationId": "getSeriesBulk",
        "summary": "Fetch multiple series at once",
        "description": "Fetch multiple series in a single request. Returns an array of SeriesData objects.",
        "parameters": [
          {
            "in": "query",
            "name": "series",
            "required": true,
            "schema": { "type": "string" },
            "description": "Comma-separated list of series names"
          },
          {
            "in": "query",
            "name": "index",
            "required": true,
            "schema": { "type": "string" },
            "description": "Index type"
          },
          {
            "in": "query",
            "name": "start",
            "schema": {
              "oneOf": [
                { "type": "integer" },
                { "type": "string" }
              ]
            }
          },
          {
            "in": "query",
            "name": "end",
            "schema": {
              "oneOf": [
                { "type": "integer" },
                { "type": "string" }
              ]
            }
          },
          {
            "in": "query",
            "name": "limit",
            "schema": { "type": "integer" }
          },
          {
            "in": "query",
            "name": "format",
            "schema": { "type": "string", "enum": ["json", "csv"] },
            "description": "Output format. Agent 21 defaults to csv for analytical retrieval."
          }
        ],
        "responses": {
          "200": {
            "description": "Array of series data",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/SeriesData" } }
              },
              "text/csv": {
                "schema": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "/api/series/cost-basis": {
      "get": {
        "operationId": "getCostBasisCohorts",
        "summary": "List cost basis cohorts",
        "description": "List available cohorts for cost basis distribution.",
        "responses": {
          "200": {
            "description": "Array of cohort names",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      }
    },
    "/api/series/cost-basis/{cohort}/dates": {
      "get": {
        "operationId": "getCostBasisDates",
        "summary": "List dates for a cost basis cohort",
        "description": "List available dates for a cohort's cost basis distribution.",
        "parameters": [
          {
            "in": "path",
            "name": "cohort",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Array of dates (YYYYMMDD format)",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "type": "integer" } }
              }
            }
          }
        }
      }
    },
    "/api/series/cost-basis/{cohort}/{date}": {
      "get": {
        "operationId": "getCostBasisDistribution",
        "summary": "Get cost basis distribution",
        "description": "Get the cost basis distribution for a cohort on a specific date.",
        "parameters": [
          {
            "in": "path",
            "name": "cohort",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "in": "path",
            "name": "date",
            "required": true,
            "schema": { "type": "string" },
            "description": "Date in YYYYMMDD format"
          },
          {
            "in": "query",
            "name": "bucket",
            "schema": { "type": "string", "enum": ["raw", "lin200", "lin500", "lin1000", "log10", "log50", "log100"] },
            "description": "Bucket type for aggregation"
          },
          {
            "in": "query",
            "name": "value",
            "schema": { "type": "string", "enum": ["supply", "realized", "unrealized"] },
            "description": "Value type: supply (BTC), realized (USD), unrealized (USD)"
          }
        ],
        "responses": {
          "200": {
            "description": "Cost basis distribution",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "/api/server/sync": {
      "get": {
        "operationId": "getSyncStatus",
        "summary": "Get indexer sync status",
        "description": "Returns sync status including indexed height, tip height, and blocks behind.",
        "responses": {
          "200": {
            "description": "Sync status",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SyncStatus" }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "operationId": "getHealth",
        "summary": "Health check",
        "description": "Returns the health status of the API server.",
        "responses": {
          "200": {
            "description": "Health status",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Health" }
              }
            }
          }
        }
      }
    }
  },
