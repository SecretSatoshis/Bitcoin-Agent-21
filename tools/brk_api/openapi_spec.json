            "description": "Array of mempool blocks",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/MempoolBlock" } }
              }
            }
          }
        }
      }
    },
    "/api/v1/difficulty-adjustment": {
      "get": {
        "operationId": "getDifficultyAdjustment",
        "summary": "Get difficulty adjustment info",
        "description": "Get current difficulty adjustment progress, estimated retarget date, and difficulty change prediction.",
        "responses": {
          "200": {
            "description": "Difficulty adjustment info",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/DifficultyAdjustment" }
